<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC "-//JasperReports//DTD Report Design//EN"
    "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport name="laporan1" pageWidth="842" pageHeight="595" columnWidth="800"
    leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- QUERY -->
    <queryString>
        <![CDATA[SELECT * FROM mahasiswa]]>
    </queryString>

    <!-- FIELD -->
    <field name="nim" class="java.lang.String"/>
    <field name="nama" class="java.lang.String"/>
    <field name="jurusan" class="java.lang.String"/>
    <field name="alamat" class="java.lang.String"/>

    <!-- TITLE -->
    <title>
        <band height="75">
            <staticText>
                <reportElement x="0" y="10" width="800" height="30"/>
                <textElement textAlignment="Center">
                    <font size="20" isBold="true"/>
                </textElement>
                <text><![CDATA[LAPORAN DATA MAHASISWA]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="40" width="800" height="20"/>
                <textElement textAlignment="Center">
                    <font size="12"/>
                </textElement>
                <text><![CDATA[Sistem Informasi Mahasiswa]]></text>
            </staticText>

            <line>
                <reportElement x="0" y="68" width="800" height="1"/>
            </line>
        </band>
    </title>

    <!-- HEADER -->
    <columnHeader>
        <band height="32">

            <!-- Background -->
            <rectangle>
                <reportElement x="0" y="0" width="800" height="32" mode="Opaque" backcolor="FFD6E0"/>
            </rectangle>

            <!-- BORDER -->
            <rectangle>
                <reportElement x="0" y="0" width="800" height="32"/>
            </rectangle>

            <!-- TEXT HEADER (DIKASIH PADDING) -->
            <staticText>
                <reportElement x="2" y="6" width="96" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[NIM]]></text>
            </staticText>

            <staticText>
                <reportElement x="102" y="6" width="196" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[NAMA]]></text>
            </staticText>

            <staticText>
                <reportElement x="302" y="6" width="146" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[JURUSAN]]></text>
            </staticText>

            <staticText>
                <reportElement x="452" y="6" width="346" height="20"/>
                <textElement textAlignment="Center"><font isBold="true"/></textElement>
                <text><![CDATA[ALAMAT]]></text>
            </staticText>

            <!-- GARIS KOLOM -->
            <line><reportElement x="100" y="0" width="1" height="32"/></line>
            <line><reportElement x="300" y="0" width="1" height="32"/></line>
            <line><reportElement x="450" y="0" width="1" height="32"/></line>

        </band>
    </columnHeader>

    <!-- DETAIL -->
    <detail>
        <band height="28">

            <!-- BORDER -->
            <rectangle>
                <reportElement x="0" y="0" width="800" height="28"/>
            </rectangle>

            <!-- GARIS KOLOM -->
            <line><reportElement x="100" y="0" width="1" height="28"/></line>
            <line><reportElement x="300" y="0" width="1" height="28"/></line>
            <line><reportElement x="450" y="0" width="1" height="28"/></line>

            <!-- DATA (SUDAH DIBERI JARAK DARI GARIS) -->
            <textField>
                <reportElement x="2" y="5" width="96" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{nim}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="102" y="5" width="196" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="302" y="5" width="146" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{jurusan}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="452" y="5" width="346" height="20"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{alamat}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- FOOTER -->
    <pageFooter>
        <band height="30">
            <staticText>
                <reportElement x="0" y="5" width="800" height="20"/>
                <textElement textAlignment="Right">
                    <font size="10"/>
                </textElement>
                <text><![CDATA[Generated by Sistem Mahasiswa]]></text>
            </staticText>
        </band>
    </pageFooter>

</jasperReport>